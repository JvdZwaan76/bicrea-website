# Cloudflare Pages: Redirects configuration
# https://developers.cloudflare.com/pages/configuration/redirects/

# Block internal documentation files from public access.
# Note: build.js also excludes these from dist/ so they should never appear
# at the production origin. This is defense-in-depth in case someone bypasses
# the build (e.g., manual deploy or build-script failure).
/README.md                   /                          301
/EMAIL-ROUTING.md            /                          301
/GA4-SETUP.md                /                          301
/SUBSTANTIATION-CHECKLIST.md /                          301

# Strip .html extension — 301 permanent redirects for SEO
/index.html                  /                          301
/mineral-title.html          /mineral-title             301
/methodology.html            /methodology               301
/distressed-properties.html  /distressed-properties     301
/about.html                  /about                     301
/process.html                /process                   301
/case-studies.html           /case-studies              301
/contact.html                /contact                   301
/privacy.html                /privacy                   301
/terms.html                  /terms                     301
/disclosures.html            /disclosures               301

# Methodology aliases
/how-we-work                 /methodology               301
/research-methodology        /methodology               301
/title-research-methodology  /methodology               301

# Common alternate URLs people might try
/services                /                          301
/services/mineral-title  /mineral-title             301
/services/distressed     /distressed-properties     301
/we-buy-houses           /distressed-properties     301
/sell-house              /distressed-properties     301
/cash-offer              /distressed-properties     301
/team                    /about                     301
/portfolio               /case-studies              301

# 404 catch-all (must be last)
# Pages Functions live under /api/* — bypass the catch-all so the
# Function-router gets the request instead of /404.html.
/api/*  /api/:splat  200

/* /404.html 404
